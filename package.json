{
  "name": "uptime-probe",
  "version": "1.0.0",
  "description": "A synthetic-monitoring CLI — declarative HTTP and real-browser checks, uptime/latency thresholds as a CI gate, webhook alerting, and a Prometheus exporter.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "probe": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "fixture-server": "tsx tests/fixtures/server.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.61.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "express": "^4.21.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
